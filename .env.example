# Neon Postgres (from Vercel integration: vercel integration add neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Clerk authentication (create an app at https://dashboard.clerk.com)
# For local builds without a real Clerk app, a format-valid test key works:
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_Y2xlcmsuZXhhbXBsZS5jb20k
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxx
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# Secret used to encrypt per-user API keys at rest (AES-256-GCM).
# Generate with: openssl rand -hex 32
APP_ENCRYPTION_KEY=your_64_char_hex_secret_here

# Suno AI API (optional server-wide fallback; users can store their own key in /settings)
SUNO_API_KEY=your_suno_api_key_here
SUNO_API_BASE_URL=https://api.suno.ai/v2

# Minimax (Hailuo) Music API (optional server-wide fallback; users can store their own key in /settings)
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_BASE_URL=https://api.minimaxi.chat/v1

# Anthropic (optional fallback for AI features when a user has no LLM key configured)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob (from Vercel dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxx
