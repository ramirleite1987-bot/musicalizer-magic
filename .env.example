# Neon Postgres (from Vercel integration: vercel integration add neon)
DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

# Suno AI API
SUNO_API_KEY=your_suno_api_key_here
SUNO_API_BASE_URL=https://api.suno.ai/v2

# Minimax (Hailuo) Music API
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_API_BASE_URL=https://api.minimaxi.chat/v1

# Anthropic (for AI theme extraction)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Vercel Blob (from Vercel dashboard > Storage > Blob)
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxx
